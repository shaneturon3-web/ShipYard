{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "allowJs": true,
    "incremental": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@core/capabilities": ["../../core/capabilities/index.ts"],
      "@core/capabilities/*": ["../../core/capabilities/*"],
      "@shared/i18n": ["../../shared/i18n/index.ts"],
      "@shared/i18n/*": ["../../shared/i18n/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
