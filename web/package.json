{
  "name": "shipyard-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build:wasm": "node wasm/tree-parser/build.mjs",
    "predeploy": "npm run build:wasm",
    "deploy": "wrangler deploy",
    "check": "wrangler check",
    "types": "wrangler types",
    "db:local": "wrangler d1 execute shipyard-db --local --file=./schema/001_init.sql && wrangler d1 execute shipyard-db --local --file=./scripts/seed-d1.sql",
    "db:migrate": "wrangler d1 execute shipyard-db --file=./schema/001_init.sql",
    "db:seed": "wrangler d1 execute shipyard-db --file=./scripts/seed-d1.sql",
    "db:orchestration:local": "wrangler d1 execute shipyard-db --local --file=./schema/002_orchestration.sql",
    "db:orchestration:remote": "wrangler d1 execute shipyard-db --remote --file=./schema/002_orchestration.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "assemblyscript": "^0.27.29",
    "typescript": "^5.8.3",
    "wrangler": "^4.19.0"
  }
}
